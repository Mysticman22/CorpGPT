DATABASE_URL=postgresql://<USERNAME>:<PASSWORD>@localhost:5432/corpgpt
SECRET_KEY=your_secret_key_here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

